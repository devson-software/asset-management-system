# ============================================================
# Monorepo .gitignore
# ============================================================

# OS
.DS_Store
.thumbs.db
Thumbs.db

# ============================================================
# Frontend (Quasar / Vue)
# ============================================================
node_modules
frontend/.quasar
frontend/dist
frontend/quasar.config.*.temporary.compiled*

# Cordova
frontend/src-cordova/node_modules
frontend/src-cordova/platforms
frontend/src-cordova/plugins
frontend/src-cordova/www

# Capacitor
frontend/src-capacitor/www
frontend/src-capacitor/node_modules

# ============================================================
# Backend (.NET)
# ============================================================
backend/**/bin/
backend/**/obj/
backend/**/.vs/
backend/**/*.user
backend/**/*.suo
backend/**/launchSettings.json

# ============================================================
# Shared
# ============================================================

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.idea
*.ntvs*
*.njsproj

# Environment / secrets
.env.local*
appsettings.*.local.json
